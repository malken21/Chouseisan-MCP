# 調整さん MCP サーバー 設定例

# 通信モード: stdio (標準入出力) または sse (Server-Sent Events)
TRANSPORT=stdio

# 待機ポート番号 (sse モードの場合のみ使用)
PORT=8000

# バインドIPアドレス (sse モードの場合のみ使用)
HOST=0.0.0.0

# ヘッドレスブラウザ動作 (true / false)
HEADLESS=true

# ログレベル (DEBUG / INFO / WARN / ERROR)
LOG_LEVEL=INFO

# DNS Rebinding Protection を無効化 (1 で無効化)
# コンテナ環境等、Host ヘッダーが 127.0.0.1/localhost 以外になる構成で
# sse モードを利用する場合に設定してください。
MCP_DISABLE_DNS_REBINDING_PROTECTION=0
